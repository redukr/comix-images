# JOJ Comic Generator - Environment Configuration

# Backend API
API_URL=http://localhost:8000

# LLM Studio (OpenAI-compatible)
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-model

# ComfyUI
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# JOJ Data Paths (adjust if needed)
JOJ_RANKS_PATH=./data/joj-ranks.json
JOJ_CARDS_PATH=./data/joj-cards.json
JOJ_IMAGES_PATH=./data/card-images

# Optional: External APIs
# OPENAI_API_KEY=your_key_here
# REPLICATE_API_TOKEN=your_token_here
